{% render 'partials/head.liquid' %}
<body>
    <header>
        <img class="butter" src="bewijsmateriaal/vlinder-wit-uitgeknipt.svg">
        <h1>Learning journal</h1>
    </header>

    <main>
        <section>
            <h2>Daily verhaaltjes van stage</h2>
            <a class="back" href="/">← Back to home</a>
            <article class="note-box">
                {% for file in files5 %}
                    <a class="notes" href="/stage/{{ file|slice:0,-3}}"> {{ file|slice:0,-3 | capitalize | replace: "-", " " }} </a>
                {% endfor %}  
            </article>
        </section>
    </main>
</body>
